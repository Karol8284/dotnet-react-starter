POSTGRES_DB=dotnetreact
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_HTTP_PORT=5000
FRONTEND_HTTP_PORT=3000
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
DEFAULT_CONNECTION=Host=db;Port=5432;Database=dotnetreact;Username=postgres;Password=postgres

JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_ISSUER=Dotnet-React-Starter-API
JWT_AUDIENCE=Dotnet-React-Starter-App
JWT_ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_IN_DAYS=7
JWT_REFRESH_TOKEN_COOKIE_NAME=drs.refreshToken
JWT_REFRESH_TOKEN_COOKIE_PATH=/api/auth
JWT_REFRESH_TOKEN_COOKIE_SAME_SITE=Lax
JWT_REFRESH_TOKEN_COOKIE_SECURE_POLICY=Always
JWT_REFRESH_TOKEN_COOKIE_IS_ESSENTIAL=true
JWT_REFRESH_TOKEN_COOKIE_DOMAIN=

CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGIN_0=http://localhost:3000
CORS_ALLOWED_ORIGIN_1=http://localhost:5173
CORS_ALLOWED_ORIGIN_2=https://localhost:5173

FRONTEND_REACT_APP_API_URL=/api
FRONTEND_NODE_OPTIONS=--max_old_space_size=4096